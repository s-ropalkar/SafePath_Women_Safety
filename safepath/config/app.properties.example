# SafePath configuration — copy to app.properties (gitignored) or use environment variables.
# NEVER commit real passwords. Prefer env vars in production (Render, etc.):
#   SAFEPATH_MYSQL_HOST, SAFEPATH_MYSQL_PORT, SAFEPATH_MYSQL_USER, SAFEPATH_MYSQL_PASSWORD
#   SAFEPATH_SMTP_PASS, SAFEPATH_GOOGLE_CLIENT_ID, SAFEPATH_APP_BASE_URL

smtp.host=smtp.gmail.com
smtp.port=587
smtp.user=your.email@gmail.com
smtp.password=your-gmail-app-password
smtp.from=your.email@gmail.com
smtp.ssl=false

google.client.id=

server.port=8080
# Email reset links: leave blank = auto-detect WiFi IP. For deploy set public URL:
# app.base.url=https://your-app.onrender.com/

# TiDB Cloud (MySQL-compatible) — local MySQL: set mysql.host=localhost mysql.port=3306 mysql.sslMode=DISABLED
mysql.host=gateway01.ap-southeast-1.prod.aws.tidbcloud.com
mysql.port=4000
mysql.database=safepath
mysql.user=your-tidb-user
mysql.password=your-tidb-password
mysql.sslMode=REQUIRED
mysql.autoCreateDatabase=false
