# SafePath configuration — copy to app.properties (gitignored) or use environment variables.
# NEVER commit real passwords. Prefer env vars in production:
#   SAFEPATH_SMTP_PASS, SAFEPATH_MYSQL_PASSWORD, SAFEPATH_GOOGLE_CLIENT_ID

smtp.host=smtp.gmail.com
smtp.port=587
smtp.user=your.email@gmail.com
smtp.password=your-gmail-app-password
smtp.from=your.email@gmail.com
smtp.ssl=false

google.client.id=

server.port=8080

mysql.host=localhost
mysql.port=3306
mysql.database=safepath
mysql.user=root
mysql.password=your-mysql-password
